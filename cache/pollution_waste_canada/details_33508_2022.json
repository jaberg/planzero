                            "4"
                        ],
                        "id": 14238,
                        "en": "Total particulate matter",
                        "fr": "Matière particulaire totale"
                    },
                    "unitType": {
                        "en": "tonnes",
                        "fr": "tonnes"
                    },
                    "comments": [
                        {
                            "type": {
                                "id": 201,
                                "en": "On-site releases comment",
                                "fr": "Commentaire sur les rejets sur le site"
                            },
                            "comment": "This facility receives wastes from municipal and private sector customers for disposal. The volume of wastes delivered to the  facility varies annually and is driven by customer generation. The quantity of wastes received at the facility increased significantly in 2023 compared to 2022 volumes, which resulted an increase of approximately 16 times the distance travelled by heavy vehicular traffic inbound and outbound to the facility using unpaved access roads year-over-year. Further, 2023 was an extremely wet year and leachate transportation quantities to off-site treatment facilities increased by a factor of 30 times more loads requiring removal from the facility than in 2022, further increasing the comparative road dust emission quantities in 2023. As a result of the extremely wet year, emission increased from year-to-year but at a much reduced rate due to a combination of the inclemency of weather and the use of dust suppressant in the drier summer months."
                        }
                    ],
                    "releaseAir": 15.566,
                    "releaseWater": null,
                    "releaseLand": null,
                    "releaseAllMedia": null,
                    "onsiteDisposal": null,
                    "offsiteDisposal": null,
